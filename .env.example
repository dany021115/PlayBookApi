DJANGO_SECRET_KEY=change-me-in-prod
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:18002,http://127.0.0.1:18002
LOG_LEVEL=INFO

DATABASE_URL=postgres://playbook:playbook@127.0.0.1:55433/playbook
REDIS_URL=redis://127.0.0.1:16381/1
CELERY_BROKER_URL=redis://127.0.0.1:16381/0

# ── Internal call to sports-odds-api (S2S JWT) ──
# Use the SAME JSON key map configured in sports-odds-api/.env INTERNAL_JWT_KEYS.
SPORTS_ODDS_API_URL=http://sports-api:8000
SPORTS_ODDS_JWT_KEYS={"v1":"DvOfQRyoDclcohLS_AtkO7yldX1NCsqz6kGX10hYB6HeO25nQVhPlrmr-kh_FAB-"}
SPORTS_ODDS_JWT_ACTIVE_KID=v1
SPORTS_ODDS_JWT_AUD=sports-odds-api
SPORTS_ODDS_JWT_ISS=playbook-api
SPORTS_ODDS_JWT_ALG=HS256

# ── LLM (OpenAI-compatible). DeepSeek default for cost. ──
LLM_PROVIDER=deepseek
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=
LLM_MODEL=deepseek-chat
LLM_TIMEOUT_SECONDS=20

# ── Push notifications (FCM HTTP v1, no Firebase SDK) ──
FCM_PROJECT_ID=
FCM_SERVICE_ACCOUNT_PATH=/app/fcm-service-account.json

# ── Email (password reset, account verify) ──
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@playbook.local
ACCOUNT_VERIFY_EMAIL_REQUIRED=False

DJANGO_SUPERUSER_EMAIL=admin@playbook.local
DJANGO_SUPERUSER_PASSWORD=admin

GUNICORN_WORKERS=2
